[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="World"
2d_physics/layer_3="ItemDrop"
2d_physics/layer_4="AxeBreakLayer"
2d_physics/layer_5="PickaxeBreakLayer"
2d_physics/layer_6="EnterDoors"
2d_physics/layer_7="PlayerHomeCollision"
2d_physics/layer_10="WoodFootsteps"
2d_physics/layer_11="StoneFootsteps"
2d_physics/layer_13="InsideTreeTopLayer"
2d_physics/layer_14="DetectOverlappingObject"

[physics]

common/enable_pause_aware_picking=true
2d/default_gravity=0

[rendering]

2d/snapping/use_gpu_pixel_snap=true
threads/thread_model=2
environment/default_environment="res://default_env.tres"
